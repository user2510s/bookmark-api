generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  email     String   @unique
  password  String   @map("password_hash")
  name      String
  lastName  String
  createdAt DateTime @default(now()) @map("created_at")
  publicId  String   @unique @default(uuid()) @map("public_id")
  id        String   @id @unique @default(uuid()) @map("user_id")

  tags String[] @map("tags_user")

  bookMark BookMark[]
  comments Comment[]

  @@map("users")
}

model BookMark {
  id     String @id @unique @default(uuid())
  userId String @map("user_id")

  title          String
  description    String
  image          String
  like           Int      @default(0) @map("like_count")
  views          Int      @default(0)
  totalRead      Int      @default(0) @map("total_read")
  totalPage      Int      @default(1) @map("total_page")
  totalReadTimer Int      @default(0) @map("total_read_timer")
  amazonLink     String
  createdAt      DateTime @default(now()) @map("created_at")

  //Tags para recomendação

  tags String[] @map("tags_post")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@map("bokmarks")
}

model Comment {
  id       String  @id @default(uuid())
  userId   String  @map("user_id")
  bookId   String  @map("book_id")
  parentId String? @map("parent_id")

  comment   String
  answerTo  String?  @map("answer_to")
  createdAt DateTime @default(now()) @map("created_at")

  bookmark BookMark @relation(fields: [bookId], references: [id], onDelete: Cascade)
  parent   Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  replies Comment[] @relation("CommentReplies")

  @@index([bookId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}
